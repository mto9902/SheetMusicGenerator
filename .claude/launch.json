{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8081"],
      "cwd": "mobile",
      "port": 8081
    },
    {
      "name": "preview-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "9090", "--directory", "backend/cache"],
      "port": 9090
    }
  ]
}
